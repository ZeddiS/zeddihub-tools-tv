<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive icon foreground — uses the square ZeddiHub logo (with the orange
  Hub tile). Inset is the standard ~33% safe zone so the system can crop to
  any shape (circle, squircle, rounded square) without clipping the logo.
-->
<inset xmlns:android="http://schemas.android.com/apk/res/android"
    android:inset="20%">
    <bitmap
        android:src="@drawable/zh_logo_square"
        android:gravity="center"
        android:antialias="true"
        android:filter="true"
        android:dither="true" />
</inset>
